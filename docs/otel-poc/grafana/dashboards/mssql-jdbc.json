{
  "title": "mssql-jdbc — driver metrics",
  "uid": "mssql-jdbc-otel-poc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "tags": ["mssql-jdbc", "otel", "poc"],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Connections / sec",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate({__name__=~\"db_client_connection_duration(_milliseconds)?_count\"}[$__rate_interval]))",
          "legendFormat": "connections/s",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Statement executions / sec",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate({__name__=~\"db_client_statement_execute_duration(_milliseconds)?_count\"}[$__rate_interval]))",
          "legendFormat": "executions/s",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors / sec",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(db_client_errors_total[$__rate_interval]))",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 0.001 },
              { "color": "red",    "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Open / closed connections (total)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum({__name__=~\"db_client_connection_duration(_milliseconds)?_count\"})",
          "legendFormat": "total connections",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Statement execute duration — p50 / p95 / p99 (ms)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate({__name__=~\"db_client_statement_execute_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"db_client_statement_execute_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate({__name__=~\"db_client_statement_execute_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Connection lifecycle latency — p95 (ms)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"db_client_connection_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "connection total",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"db_client_connection_prelogin_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "prelogin",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"db_client_connection_login_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "login",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"db_client_connection_token_acquisition_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "token_acquisition",
          "refId": "D"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Statement-pipeline stages — p95 (ms)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"db_client_statement_request_build_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "request_build",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"db_client_statement_first_server_response_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "first_server_response",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"db_client_statement_prepare_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "prepare",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"db_client_statement_prepexec_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "prepexec",
          "refId": "D"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"db_client_statement_execute_duration(_milliseconds)?_bucket\"}[$__rate_interval])))",
          "legendFormat": "execute",
          "refId": "E"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Errors by type",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (error_type, db_operation) (rate(db_client_errors_total[$__rate_interval]))",
          "legendFormat": "{{db_operation}} / {{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } }
    }
  ]
}
